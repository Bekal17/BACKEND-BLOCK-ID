# ===== BlockID Production Configuration Template =====
# Copy to .env and fill in secrets. Do NOT commit .env or keypairs to repo.
# Use secure path for keypair (e.g. /secure/path/oracle-keypair.json)

# ===== SOLANA =====
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Multi-RPC failover (comma-separated override; else Helius, Solana, RPC Pool)
# RPC_ENDPOINTS=https://mainnet.helius-rpc.com/?api-key=xxx,https://api.mainnet-beta.solana.com
RPC_TIMEOUT=5
RPC_MAX_RETRIES=3
RPC_CACHE_SECONDS=300
SOLANA_CLUSTER=mainnet
SOLANA_NETWORK=mainnet

ORACLE_PROGRAM_ID=CxQ4mo9UQxVZMQ3T9oxvtYL7huBAGMjF8nTxL7XnkuTe
# Path to oracle keypair JSON (BlockID uses ORACLE_PRIVATE_KEY)
ORACLE_PRIVATE_KEY=/secure/path/oracle-keypair.json

# ===== HELIUS =====
HELIUS_API_KEY=your_key_here
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=xxx
HELIUS_MAX_WALLETS_PER_RUN=500
HELIUS_INCREMENTAL_FETCH=1

# ===== DATABASE =====
# SQLite (default)
DB_URL=sqlite:///blockid.db
DB_PATH=blockid.db

# PostgreSQL (alternative)
# DB_URL=postgres://user:pass@host:5432/blockid

# ===== PIPELINE =====
BLOCKID_TEST_MODE=0
BLOCKID_PIPELINE_MODE=0
BLOCKID_REALTIME_MODE=1
BLOCKID_MAX_WALLETS=500
BLOCKID_MAX_WALLETS_PER_RUN=500
BLOCKID_DRY_RUN=0
BLOCKID_SKIP_PUBLISH=0
BLOCKID_SKIP_HELIUS=0
BLOCKID_USE_DUMMY_DATA=0

# ===== TRUST LOGIC =====
CONFIDENCE_THRESHOLD=0.72
REVIEW_QUEUE_ENABLED=1
AUTO_PUBLISH_ENABLED=1

# ===== SCORE DECAY =====
DECAY_ENABLED=1
DECAY_MAX_SCORE=80

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=logs/blockid.log

# ===== ALERTS =====
ALERT_TELEGRAM_TOKEN=
ALERT_EMAIL=

# ===== BILLING (Stripe) =====
# BILLING_ENABLED=0
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_...
# BILLING_SUCCESS_URL=https://app.blockidscore.fun/billing/success
# BILLING_CANCEL_URL=https://app.blockidscore.fun/billing

# ===== MONITORING =====
ENABLE_HEALTHCHECK=1
ENABLE_METRICS=1

# ===== FUTURE UPGRADES =====
# Kubernetes secrets, Hashicorp Vault, AWS Parameter Store
# Multi-region RPC fallback

# ===== EXAMPLE PRODUCTION RUN (PowerShell) =====
# setx SOLANA_CLUSTER mainnet
# setx SOLANA_NETWORK mainnet
# setx BLOCKID_TEST_MODE 0
# setx BLOCKID_DRY_RUN 0
# py -m backend_blockid.tools.run_full_pipeline
