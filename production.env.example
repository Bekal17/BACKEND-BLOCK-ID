# BlockID Production Environment
# Copy to production.env and fill in secrets before: docker compose up
# Do NOT commit production.env (add to .gitignore)

# ===== SOLANA =====
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet

# ===== BLOCKID =====
BLOCKID_TEST_MODE=0
BLOCKID_MAX_WALLETS=50000
BLOCKID_PIPELINE_MODE=0
BLOCKID_USE_DUMMY_DATA=0

# ===== HELIUS =====
HELIUS_API_KEY=your_helius_key_here

# ===== DATABASE (SQLite in Docker) =====
DB_PATH=/app/data/blockid.db

# ===== TRUST =====
CONFIDENCE_THRESHOLD=0.72
