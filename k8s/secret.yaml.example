# BlockID Kubernetes Secret Template
# Copy to secret.yaml, fill in values, then: kubectl apply -f k8s/secret.yaml
# DO NOT commit secret.yaml (add to .gitignore)

apiVersion: v1
kind: Secret
metadata:
  name: blockid-secrets
  namespace: blockid
type: Opaque
stringData:
  HELIUS_API_KEY: "your_helius_api_key_here"
  ORACLE_SIGNER_KEYPAIR: "base64_or_json_keypair_here"
